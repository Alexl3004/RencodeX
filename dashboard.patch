+    <!-- Grille de stats -->
+    <div class="grid grid-cols-2 gap-3">
+      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-[2px] p-3">
+        <div class="section-label mb-1.5">Fichiers encodés</div>
